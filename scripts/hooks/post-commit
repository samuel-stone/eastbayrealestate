#!/bin/bash

echo "=== Git Post-Commit Hook Triggered ==="

if [ -f .env ]; then
    export $(cat .env | grep -v '#' | xargs)
fi

if [ -d ".venv" ]; then
    PYTHON_BIN=".venv/bin/python"
elif [ -d "venv" ]; then
    PYTHON_BIN="venv/bin/python"
else
    PYTHON_BIN="python3"
fi

echo "[+] Triggering automated post-commit AI code reviewer..."
$PYTHON_BIN -m automation_engine.code_reviewer

echo "=== Post-Commit Reports & Proposals Logged to Agent Memory ==="
